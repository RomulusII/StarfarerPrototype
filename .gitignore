*.pdb.meta
*.mdb.meta

# Unity3D crash raporları
sysinfo.txt

# Builds
*.apk
*.aab
*.unitypackage
*.app
*.exe
*.x86_64
*.x86

# Crashlytics
crashlytics-build.properties

# Packed Addressables
/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*

# Temporary auto-generated Android Assets
/[Aa]ssets/[Ss]treamingAssets/aa.meta
/[Aa]ssets/[Ss]treamingAssets/aa/*

# MacOS sistem dosyaları
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Icon?
ehthumbs.db
[Tt]humbs.db

# Windows sistem dosyaları
Thumbs.db
Desktop.ini

# JetBrains Rider
*.sln
*.csproj

# ASLA yoksayılmaması gereken dosyalar
!*.meta
!*.unity
!*.prefab
!*.mat
!*.asset