/StarfarerPrototype/[Tt]emp/
/StarfarerPrototype/[Oo]bj/
/StarfarerPrototype/[Bb]uild/
/StarfarerPrototype/[Bb]uilds/
/StarfarerPrototype/[Ll]ogs/
/StarfarerPrototype/[Uu]ser[Ss]ettings/
/StarfarerPrototype/[Mm]emoryCaptures/

# Asset Store araçları klasörü
/[Aa]ssets/AssetStoreTools*

# Visual Studio / VS Code / Rider
.vs/
.vscode/
.idea/
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity3D tarafından oluşturulan dosyalar
